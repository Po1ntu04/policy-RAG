# Default: ignore everything at repository root.
/*

# Keep essential repository files.
!/.gitignore
!/README.md
!/pyproject.toml
!/poetry.lock
!/Makefile
!/version.txt
!/.dockerignore
!/docker-compose.yaml
!/Dockerfile.llamacpp-cpu
!/Dockerfile.ollama
!/settings.yaml
!/settings-azopenai.yaml
!/settings-docker.yaml
!/settings-gemini.yaml
!/settings-local.yaml
!/settings-mock.yaml
!/settings-ollama-pg.yaml
!/settings-ollama.yaml
!/settings-openai.yaml
!/settings-qwen.yaml
!/settings-sagemaker.yaml
!/settings-test.yaml
!/settings-vllm.yaml

# Keep essential source directories.
!/.docker/
!/db/
!/frontend/
!/private_gpt/
!/scripts/

# Allow files inside the kept directories.
!/.docker/**
!/db/**
!/frontend/**
!/private_gpt/**
!/scripts/**

# Remove non-source or local-only files inside kept directories.
db/README.md
frontend/node_modules/
frontend/dist/
frontend/.cache/
frontend/.eslintcache
scripts/*.local.cmd
scripts/debug_storage_state.py
scripts/extract_openapi.py
scripts/inspect_ingest_records.py
backup_local/

# Python caches / test artifacts
__pycache__/
*.py[cod]
.ruff_cache/
.pytest_cache/
.mypy_cache/
.pyre/
.coverage
coverage.xml
htmlcov/
tests-results.xml
/.python-version

# Local environments / secrets
.venv/
venv/
.env
.env.*
!.env.example
settings-me.yaml

# Runtime data / temporary files
local_data/
models/
tiktoken_cache/
input_file/
*.log
*.tmp
*.temp
*.mp4
*.avi
*.mov
*.docx
*.aux
*.bbl
*.bcf
*.blg
*.cb
*.cb2
*.fdb_latexmk
*.fls
*.fmt
*.fot
*.lof
*.lot
*.nav
*.out
*.run.xml
*.snm
*.synctex
*.synctex.gz
*.toc
*.xdv

# IDE / OS
.idea/
.vscode/
/.run/
.fleet/
.DS_Store
Thumbs.db
