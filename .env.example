# Policy-RAG local development example.
# Copy to .env or configure these variables in your shell before starting.

PGPT_PROFILES=qwen

# Qwen / DashScope OpenAI-compatible API.
DASHSCOPE_API_KEY=<your_dashscope_api_key>

# Optional Hugging Face token for downloading embedding models.
HF_TOKEN=<your_huggingface_token>

# Application auth secret. Replace in any non-demo environment.
PGPT_AUTH_SECRET=<your_auth_secret>

# Enable Postgres-backed policy metadata, indicators, RBAC, comments, and audits.
PGPT_INDICATOR_STORE=postgres
PGPT_AUTO_MIGRATE=1
PGPT_DB_MAXCONN=5

# Postgres connection.
PGPT_POSTGRES_HOST=localhost
PGPT_POSTGRES_PORT=5432
PGPT_POSTGRES_DB=gov_rag
PGPT_POSTGRES_USER=postgres
PGPT_POSTGRES_PASSWORD=<your_postgres_password>

# Optional local folder ingestion guard. Keep false unless using scripts/ingest_folder.py.
LOCAL_INGESTION_ENABLED=false
